{
  "name": "@pond/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pond browser extension: capture saves from Twitter/X, Instagram, Pinterest, Are.na, Cosmos, TikTok, YouTube and any article into the local Pond library.",
  "license": "MIT",
  "author": {
    "name": "Raphael Salaja",
    "url": "https://github.com/raphaelsalaja"
  },
  "homepage": "https://github.com/raphaelsalaja/pond#readme",
  "bugs": {
    "url": "https://github.com/raphaelsalaja/pond/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raphaelsalaja/pond.git",
    "directory": "apps/extension"
  },
  "scripts": {
    "build": "wxt build",
    "dev": "wxt",
    "postinstall": "wxt prepare",
    "typecheck": "wxt prepare && tsc --noEmit",
    "zip": "wxt zip"
  },
  "dependencies": {
    "@pond/schema": "workspace:*"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.40",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "wxt": "^0.20.25"
  }
}
