{
  "$schema": "https://v2-9-8.turborepo.dev/schema.json",
  "ui": "tui",
  "globalDependencies": ["tsconfig.base.json", "pnpm-workspace.yaml", ".env"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "public/**",
        "entrypoints/**",
        "sources/**",
        "utils/**",
        "package.json",
        "tsconfig.json",
        "electron.vite.config.ts",
        "electron-builder.yml",
        "wxt.config.ts"
      ],
      "outputs": ["out/**", ".output/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "../../biome.json"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json"],
      "outputs": []
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "dist": {
      "dependsOn": ["build"],
      "inputs": [
        "out/**",
        "electron-builder.yml",
        "resources/**",
        "package.json"
      ],
      "outputs": ["dist/**"]
    }
  }
}
