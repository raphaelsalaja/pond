{
  "name": "pond",
  "private": true,
  "version": "0.1.0",
  "description": "A local-first archive for everything you save across Twitter/X, Instagram, Pinterest, Are.na, Cosmos, TikTok, YouTube, and any web article.",
  "license": "MIT",
  "author": {
    "name": "Raphael Salaja",
    "url": "https://github.com/raphaelsalaja"
  },
  "homepage": "https://github.com/raphaelsalaja/pond#readme",
  "bugs": {
    "url": "https://github.com/raphaelsalaja/pond/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raphaelsalaja/pond.git"
  },
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check . --write --unsafe",
    "lint:check": "biome ci .",
    "typecheck": "turbo run typecheck",
    "dist": "turbo run dist",
    "dist:mac": "pnpm --filter @pond/desktop dist:mac",
    "dist:win": "pnpm --filter @pond/desktop dist:win",
    "dist:linux": "pnpm --filter @pond/desktop dist:linux",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "turbo": "^2.9.8",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.9",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm": "0.36.4",
      "vite": "^6.3.4",
      "vite-node": "^3.2.4"
    }
  }
}
