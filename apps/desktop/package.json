{
  "name": "@pond/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pond desktop app: local-first archive with a menu-bar tray, local SQLite index and filesystem library.",
  "license": "MIT",
  "author": {
    "name": "Raphael Salaja",
    "url": "https://github.com/raphaelsalaja"
  },
  "homepage": "https://github.com/raphaelsalaja/pond#readme",
  "bugs": {
    "url": "https://github.com/raphaelsalaja/pond/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raphaelsalaja/pond.git",
    "directory": "apps/desktop"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "postinstall": "node ./scripts/rebuild-native.mjs || true && node ./scripts/download-yt-dlp.mjs || true",
    "rebuild": "node ./scripts/rebuild-native.mjs",
    "rebuild:sqlite": "electron-rebuild -f -w better-sqlite3",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac --arm64 --x64",
    "dist:mac:arm64": "electron-vite build && electron-builder --mac --arm64",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "db:generate": "ELECTRON_RUN_AS_NODE=1 pnpm exec electron ./node_modules/drizzle-kit/bin.cjs generate",
    "db:push": "ELECTRON_RUN_AS_NODE=1 pnpm exec electron ./node_modules/drizzle-kit/bin.cjs push",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@napi-rs/keyring": "^1.3.0",
    "@pond/icons": "workspace:*",
    "@pond/schema": "workspace:*",
    "@pond/ui": "workspace:*",
    "@tanstack/react-table": "^8.21.3",
    "@uiw/color-convert": "^2.10.1",
    "@uiw/react-color-hue": "^2.10.1",
    "@uiw/react-color-saturation": "^2.10.1",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.9.0",
    "chrono-node": "^2.9.1",
    "drizzle-orm": "^0.45.2",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.2.0",
    "fuse.js": "^7.3.0",
    "hono": "^4.12.18",
    "sqlite-vec": "^0.1.7-alpha.2",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/rebuild": "^4.0.4",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "electron-builder-squirrel-windows": "^26.8.1",
    "electron-vite": "^5.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.15.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "zod": "^4.4.3"
  }
}
