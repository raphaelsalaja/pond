# Neon Postgres (provision via Vercel Marketplace -> Storage -> Neon)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Vercel Blob (provision via Vercel Storage -> Blob)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Single-user API key the extension uses to authenticate to /api/ingest.
# Generate with: openssl rand -hex 32
POND_INGEST_KEY="paste-a-long-random-string-here"
