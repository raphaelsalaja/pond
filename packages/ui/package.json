{
  "name": "@pond/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Headless React primitives for Pond — thin Base UI wrappers (Button, Dialog, Popover, Toast, ...) styled with CSS Modules. App-agnostic; zero coupling to the desktop app's pool/state.",
  "license": "MIT",
  "author": {
    "name": "Raphael Salaja",
    "url": "https://github.com/raphaelsalaja"
  },
  "homepage": "https://github.com/raphaelsalaja/pond#readme",
  "bugs": {
    "url": "https://github.com/raphaelsalaja/pond/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raphaelsalaja/pond.git",
    "directory": "packages/ui"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./reset.css": "./src/reset.css",
    "./theme.css": "./src/theme.css"
  },
  "scripts": {
    "lint": "biome check --fix --unsafe .",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@radix-ui/colors": "^3.0.0",
    "@radix-ui/themes": "^3.3.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.2",
    "typescript": "^6.0.3"
  }
}
